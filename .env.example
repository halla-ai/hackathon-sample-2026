# Copy this file to .env for local development.
# Keep .env local. Never commit real keys, endpoints, or deployment secrets.

# Foundry / Azure OpenAI endpoint, for example:
# https://<resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# API key from the assigned Foundry or Azure OpenAI project.
AZURE_OPENAI_API_KEY=

# Exact deployment name shown in Foundry. This is case-sensitive.
AZURE_OPENAI_DEPLOYMENT=

# Keep this value unless your tutor or operations team gives a different one.
AZURE_OPENAI_API_VERSION=2024-12-01-preview
